# Copy to .env.local for local dev; set these in the Vercel project's Environment Variables.
# NEVER commit real values.

# Login password for the whole app (single shared password).
APP_PASSWORD=CHANGE_ME

# HMAC secret for the signed session cookie. Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME

# The VM control-API TLS endpoint (pinned self-signed). e.g. https://<static-ip>
VM_CONTROL_URL=https://CHANGE_ME

# Shared bearer secret the VM control-API requires.
VM_CONTROL_SECRET=CHANGE_ME

# The VM's self-signed CA, so the serverless proxy can pin/trust it.
# Accepts base64 (recommended — no newline issues in env UIs) OR the literal PEM.
VM_CA_CERT=CHANGE_ME
